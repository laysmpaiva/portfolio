---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profile, career, funnel, skillsOrbit } from '../data/content.ts';

// orbit node positions: two ellipses around the center
const ring = (items: any[], rx: number, ry: number, offset: number) =>
  items.map((it, i) => {
    const angle = ((offset + (360 / items.length) * i) * Math.PI) / 180;
    return { ...it, x: 50 + rx * Math.cos(angle), y: 50 + ry * Math.sin(angle) };
  });
const innerNodes = ring(skillsOrbit.inner, 26, 23, -90);
const outerNodes = ring(skillsOrbit.outer, 41, 39, -75);
const orbitColor = (g: string) => (skillsOrbit.groups.find((gr) => gr.key === g) || {}).color || 'cobalt';

// infographic funnel (ref: Oleksii Kolosov's animated sales funnel):
// stacked ribbon slices with folded corners, names inside, labels alternating sides
const FCX = 500;
const F_TOP = 40, F_BOT = 520;
const HW_TOP = 230, HW_BOT = 56;
const halfW = (y: number) => HW_TOP - (HW_TOP - HW_BOT) * ((y - F_TOP) / (F_BOT - F_TOP));
const SEG_H = 88, SEG_STEP = 96;
// site palette progression: cobalt → lilac → pink → coral → sun
const sliceFills = ['#2D4DFF', '#C7B4FF', '#FF8FCF', '#FF5A36', '#FFC93C'];
const sliceDark = ['#1D33B8', '#8F6BE8', '#E0559E', '#C73415', '#D99E0B'];
const sliceText = ['#FBF6E7', '#141210', '#141210', '#FBF6E7', '#141210'];
const fSegs = Array.from({ length: 5 }, (_, i) => {
  const y1 = F_TOP + i * SEG_STEP;
  const y2 = y1 + SEG_H;
  const yc = (y1 + y2) / 2;
  const w1 = halfW(y1);
  const w2 = halfW(y2);
  const left = i % 2 === 0;
  return {
    d: `M ${FCX - w1} ${y1} L ${FCX + w1} ${y1} L ${FCX + w2} ${y2} L ${FCX - w2} ${y2} Z`,
    // folded ribbon corners on the top edge
    foldL: `M ${FCX - w1} ${y1} L ${FCX - w1 - 16} ${y1 - 13} L ${FCX - w1 + 22} ${y1} Z`,
    foldR: `M ${FCX + w1} ${y1} L ${FCX + w1 + 16} ${y1 - 13} L ${FCX + w1 - 22} ${y1} Z`,
    yc, w1, w2,
    left,
    // label block position as % of the 1000x600 viewBox
    labTop: ((yc - 26) / 600) * 100,
    labEdge: ((500 - halfW(yc) - 42) / 1000) * 100, // distance from center to slice edge, as x fraction
  };
});
---

<Layout title="About · Lays Paiva" description="Career, day-to-day work and skills of growth marketer Lays Paiva.">
  <Nav active="about" />

  <!-- intro -->
  <section class="ab-hero">
    <div class="wrap ab-hero__inner">
      <div>
        <p class="eyebrow reveal">About me</p>
        <h1 class="display ab-hero__title reveal">HI, I'M LAYS<span class="dot">.</span></h1>
        <p class="ab-hero__lead reveal">{profile.blurb}</p>
        <p class="ab-hero__loc mono muted reveal">{profile.location}</p>
        <div class="ab-hero__actions reveal">
          <a href="/#work" class="btn">See my work →</a>
          <a href={`mailto:${profile.email}`} class="btn btn--ghost">Email me ✉</a>
        </div>
      </div>
      <div class="ab-hero__photo reveal">
        <figure class="photo r-1">
          <img src={profile.photo} alt="Lays Paiva" width="360" height="360" loading="eager" onerror="this.onerror=null;this.src='/lays-placeholder.svg'" />
        </figure>
      </div>
    </div>
  </section>

  <!-- career -->
  <section class="ab-career">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">01</span> Companies I've grown</h2>
      <div class="timeline">
        {career.spotlight.map((j) => (
          <article class={`job card reveal ${j.now ? 'job--now accent-acid' : 'accent-cobalt'}`}>
            <div class="job__head">
              <div>
                <h3 class="job__co">{j.company} {j.now ? <span class="job__badge">NOW</span> : null}</h3>
                <p class="job__role">{j.role}</p>
              </div>
              <div class="job__meta mono muted">
                <span>{j.period}</span><br /><span>{j.type}</span>
              </div>
            </div>
            <p class="job__body">{j.body}</p>
            <ul class="job__points">
              {j.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <p class="eyebrow ab-earlier-label reveal">◆ Earlier roles</p>
      <div class="earlier">
        {career.earlier.map((e, i) => (
          <span class={`earlier__chip card reveal--pop r-${(i % 4) + 1}`}>
            <b>{e.company}</b><span class="mono muted"> · {e.role}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- the whole funnel -->
  <section class="ab-funnel">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">02</span> I grow the whole funnel</h2>
      <p class="section-lead reveal muted">{funnel.lead}</p>
      <div class="funnel" data-funnel>
        <div class="funnel__fig">
          <svg class="funnel__svg" viewBox="0 -60 1000 660" aria-hidden="true">
            <defs>
              {fSegs.map((s, i) => (
                <linearGradient id={`fgrad-${i}`} x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color={sliceFills[i]} stop-opacity="0.62" />
                  <stop offset="100%" stop-color={sliceFills[i]} />
                </linearGradient>
              ))}
              <filter id="fsoft" x="-30%" y="-30%" width="160%" height="160%">
                <feDropShadow dx="0" dy="9" stdDeviation="9" flood-color="#141210" flood-opacity="0.16" />
              </filter>
              <marker id="farrowhead" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
                <path d="M 1 1 L 7 4 L 1 7" fill="none" stroke="#8a857d" stroke-width="1.4" stroke-linecap="round" />
              </marker>
            </defs>

            <!-- arrows feeding the mouth -->
            <g class="farrows">
              <path class="farrow" d="M 300 -34 C 360 -56, 430 -42, 466 -2" marker-end="url(#farrowhead)" style="--d:1.25s" />
              <path class="farrow" d="M 500 -48 L 500 -6" marker-end="url(#farrowhead)" style="--d:1.4s" />
              <path class="farrow" d="M 700 -34 C 640 -56, 570 -42, 534 -2" marker-end="url(#farrowhead)" style="--d:1.55s" />
            </g>

            <!-- ribbon slices, names inside, folded corners -->
            {fSegs.map((s, i) => (
              <g class="fband" data-band={i} style={`--d:${0.15 + i * 0.16}s`}>
                <path d={s.d} fill={`url(#fgrad-${i})`} filter="url(#fsoft)" />
                <text x={FCX} y={s.yc + 2} text-anchor="middle" dominant-baseline="middle" class="fband__t" fill={sliceText[i]} style={`font-size:${24 - i * 1.5}px`}>
                  {funnel.stages[i].t}
                </text>
              </g>
            ))}
          </svg>

          <!-- alternating side labels (desktop) -->
          {fSegs.map((s, i) => (
            <div
              class={`flab ${s.left ? 'flab--l' : 'flab--r'}`}
              data-band={i}
              style={`top:${s.labTop}%; ${s.left ? `right:${100 - s.labEdge}%` : `left:${100 - s.labEdge}%`}; --d:${0.5 + i * 0.16}s; --fx:${s.left ? '-18px' : '18px'}`}
            >
              <div class="flab__in">
                <h3 class="flab__t">{funnel.stages[i].icon} {funnel.stages[i].t}</h3>
                <p class="flab__d">{funnel.stages[i].d}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- mobile fallback: stacked stage cards -->
        <div class="funnel__stages">
          {funnel.stages.map((st, i) => (
            <div class={`fstage card reveal accent-${st.color}`} data-stage={i}>
              <div class="fstage__head">
                <span class="fstage__icon" aria-hidden="true">{st.icon}</span>
                <h3 class="fstage__t">{st.t}</h3>
                <span class="fstage__sub mono muted">{st.sub}</span>
              </div>
              <p class="fstage__d muted">{st.d}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- skills orbit -->
  <section class="ab-skills">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">03</span> The toolkit</h2>
      <p class="section-lead reveal muted">Everything orbits one job: growth. Hover around.</p>
      <div class="orbit reveal" data-orbit>
        <div class="orbit__stage">
          <svg class="orbit__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
            <ellipse class="orbit__ring" cx="50" cy="50" rx="26" ry="23" />
            <ellipse class="orbit__ring" cx="50" cy="50" rx="41" ry="39" />
            {innerNodes.map((n, i) => (
              <line class="orbit__line" x1="50" y1="50" x2={n.x} y2={n.y} style={`--d:${0.1 + i * 0.05}s`} />
            ))}
          </svg>
          {innerNodes.map((n, i) => (
            <div class={`onode onode--${orbitColor(n.g)}`} style={`left:${n.x}%; top:${n.y}%; --d:${0.15 + i * 0.06}s; --fd:${-(i * 0.7)}s`}>
              <span class="onode__i" aria-hidden="true">{n.i}</span>{n.n}
            </div>
          ))}
          {outerNodes.map((n, i) => (
            <div class={`onode onode--sm onode--${orbitColor(n.g)}`} style={`left:${n.x}%; top:${n.y}%; --d:${0.5 + i * 0.05}s; --fd:${-(i * 0.55)}s`}>
              <span class="onode__i" aria-hidden="true">{n.i}</span>{n.n}
            </div>
          ))}
          <div class="orbit__center" style="--d:.05s">GROWTH</div>
        </div>
        <div class="orbit__legend">
          {skillsOrbit.groups.map((g) => (
            <span class="orbit__leg mono"><i class={`bg-${g.color}`}></i>{g.label}</span>
          ))}
        </div>
        <ul class="orbit__list">
          {[...skillsOrbit.inner, ...skillsOrbit.outer].map((n) => (
            <li class={`tag onode--${orbitColor(n.g)}`}>{n.i} {n.n}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- contact -->
  <section id="contact" class="contact">
    <div class="wrap center">
      <p class="eyebrow reveal">◉ open to growth & marketing lead roles</p>
      <h2 class="display contact__title reveal">LET'S<br>GROW<br>SOMETHING</h2>
      <div class="contact__actions reveal">
        <a href={`mailto:${profile.email}`} class="btn btn--cobalt">Email me ✉</a>
        <a href={profile.socials[0].href} class="btn btn--ghost">LinkedIn ↗</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* tighter section rhythm on this page */
  section { padding-block: clamp(2.4rem, 5vw, 4.5rem); }

  /* intro */
  .ab-hero { padding-top: clamp(2rem, 5vw, 3.5rem); }
  .ab-hero__inner { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 2.5rem; align-items: center; }
  .ab-hero__title { font-size: clamp(2.2rem, 5.6vw, 4.6rem); white-space: nowrap; }
  .ab-hero__title .dot { color: var(--coral); }
  .ab-hero__lead { font-size: clamp(1.15rem, 2.4vw, 1.6rem); font-weight: 500; line-height: 1.35; margin: 1.2rem 0 0.8rem; max-width: 44ch; }
  .ab-hero__loc { font-size: 0.85rem; }
  .ab-hero__actions { display: flex; gap: 0.9rem; flex-wrap: wrap; margin-top: 1.6rem; }
  .ab-hero__photo { position: relative; justify-self: center; }
  .ab-hero__photo .photo { margin: 0; background: var(--paper-2); border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow-lg); padding: 10px; width: min(70vw, 280px); }
  .ab-hero__photo img { display: block; width: 100%; aspect-ratio: 1/1; object-fit: cover; border: 2px solid var(--ink); }
  @media (max-width: 760px) { .ab-hero__inner { grid-template-columns: 1fr; } .ab-hero__photo { order: -1; } }

  /* video */
  .ab-video__frame { border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow-lg); overflow: hidden; aspect-ratio: 16 / 9; background: var(--ink); max-width: 900px; }
  .ab-video__frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  .ab-video .section-h .num { color: var(--coral); }

  /* career */
  .timeline { display: flex; flex-direction: column; gap: 1.6rem; }
  .job { padding: 1.6rem 1.7rem; }
  .job__head { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .job__co { font-size: 1.4rem; display: flex; align-items: center; gap: 0.6rem; }
  .job__badge { font-family: var(--font-mono); font-size: 0.6rem; background: var(--ink); color: var(--acid); padding: 0.3em 0.6em; border-radius: 999px; letter-spacing: 0.1em; }
  .job__role { font-weight: 600; color: var(--ink-soft); }
  .job__meta { font-size: 0.78rem; text-align: right; }
  .job__body { margin: 1rem 0 0.8rem; font-size: 1rem; line-height: 1.45; }
  .job__points { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .job__points li { position: relative; padding-left: 1.4rem; font-size: 0.92rem; color: var(--ink-soft); }
  .job__points li::before { content: "→"; position: absolute; left: 0; color: var(--coral); font-weight: 700; }
  .ab-earlier-label { margin: 2.4rem 0 1rem; }
  .earlier { display: grid; grid-template-columns: repeat(2, max-content); gap: 0.8rem; }
  @media (max-width: 640px) { .earlier { grid-template-columns: 1fr; } }
  .earlier__chip { padding: 0.6em 1em; font-size: 0.9rem; box-shadow: var(--shadow-sm); }
  @media (max-width: 620px) { .job__meta { text-align: left; } }

  /* the whole funnel: infographic style (slices + alternating labels) */
  .funnel__fig { position: relative; max-width: 1060px; margin-inline: auto; }
  .funnel__svg { width: 100%; height: auto; overflow: visible; display: block; }
  .fband { opacity: 0; transform-box: fill-box; transform-origin: center; transition: transform 0.25s var(--ease-out); }
  .funnel-on .fband {
    animation: bandin 0.6s var(--ease-spring) both, fbob 4.6s ease-in-out infinite;
    animation-delay: var(--d, 0s), calc(var(--d, 0s) + 0.9s);
  }
  @keyframes bandin { from { opacity: 0; transform: translateY(-24px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fbob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
  .fband path { transform-box: fill-box; transform-origin: center; transition: transform 0.3s var(--ease-out); }
  .fband.hl path { animation: hlpulse 0.55s var(--ease-spring); transform: scale(1.045); }
  .fband__t { font-family: var(--font-display); font-weight: 700; letter-spacing: 0.02em; pointer-events: none; }
  .fband, .flab { cursor: default; }
  .flab__in { transition: transform 0.3s var(--ease-out); }
  .flab--l .flab__in { transform-origin: right center; }
  .flab--r .flab__in { transform-origin: left center; }
  .flab.hl .flab__in { animation: hlpulse 0.55s var(--ease-spring); transform: scale(1.08); }
  .flab.hl .flab__d { color: var(--ink); }
  @keyframes hlpulse {
    0%   { transform: scale(1); }
    45%  { transform: scale(1.14); }
    100% { transform: scale(var(--hl-rest, 1.06)); }
  }
  .fband.hl path { --hl-rest: 1.045; }
  .flab.hl .flab__in { --hl-rest: 1.08; }
  .farrow { fill: none; stroke: #8a857d; stroke-width: 2; stroke-linecap: round; stroke-dasharray: 220; stroke-dashoffset: 220; opacity: 0; }
  .funnel-on .farrow { animation: farrowin 0.7s ease forwards; animation-delay: var(--d, 1.3s); }
  @keyframes farrowin { from { stroke-dashoffset: 220; opacity: 0; } to { stroke-dashoffset: 0; opacity: 1; } }
  .flab { position: absolute; width: min(24%, 250px); opacity: 0; }
  .funnel-on .flab { animation: flabin 0.55s var(--ease-out) both; animation-delay: var(--d, 0s); }
  @keyframes flabin { from { opacity: 0; transform: translateX(var(--fx, -18px)); } to { opacity: 1; transform: translateX(0); } }
  .flab--l { text-align: right; }
  .flab--r { text-align: left; }
  .flab__t { font-size: clamp(0.95rem, 1.6vw, 1.2rem); font-weight: 700; margin-bottom: 0.3rem; }
  .flab__d { font-size: clamp(0.72rem, 1.1vw, 0.85rem); line-height: 1.45; color: var(--ink-soft); }
  .funnel__stages { display: none; }
  @media (max-width: 880px) {
    .funnel__fig { display: none; }
    .funnel__stages { display: flex; flex-direction: column; gap: 1rem; }
    .fstage { padding: 1.1rem 1.4rem; }
    .fstage__head { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; }
    .fstage__icon { font-size: 1.4rem; }
    .fstage__t { font-size: 1.15rem; text-transform: uppercase; }
    .fstage__sub { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
    .fstage__d { font-size: 0.92rem; line-height: 1.45; margin-top: 0.4rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .funnel-on .fband, .funnel-on .farrow, .funnel-on .flab { animation-duration: 0.01s; }
  }

  /* skills orbit */
  .orbit__stage { position: relative; height: clamp(440px, 56vw, 640px); }
  .orbit__svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .orbit__ring { fill: none; stroke: var(--ink); stroke-width: 1.2; stroke-dasharray: 5 6; vector-effect: non-scaling-stroke; opacity: 0.25; }
  .orbit__line { stroke: var(--ink); stroke-width: 1.2; vector-effect: non-scaling-stroke; opacity: 0; }
  .orbit-on .orbit__line { animation: olinein 0.5s ease both; animation-delay: var(--d, 0s); }
  @keyframes olinein { from { opacity: 0; } to { opacity: 0.18; } }
  .onode {
    position: absolute; z-index: 1; transform: translate(-50%,-50%); opacity: 0;
    background: var(--paper-2); border: 2.5px solid var(--ink); border-radius: 999px; box-shadow: var(--shadow-sm);
    padding: 0.45rem 0.8rem; font-size: clamp(0.64rem, 1.1vw, 0.82rem); font-weight: 700; white-space: nowrap;
    display: inline-flex; align-items: center; gap: 0.4em;
    transition: scale 0.2s var(--ease-spring), box-shadow 0.2s ease;
  }
  .orbit-on .onode { animation: opop 0.45s var(--ease-spring) both, ofloat 5.4s ease-in-out infinite; animation-delay: var(--d, 0s), var(--fd, 0s); }
  @keyframes opop { from { opacity: 0; scale: 0; } to { opacity: 1; scale: 1; } }
  @keyframes ofloat {
    0%, 100% { transform: translate(-50%, -50%); }
    50%      { transform: translate(-50%, calc(-50% - 10px)); }
  }
  .onode:hover { scale: 1.15; z-index: 4; box-shadow: var(--shadow); }
  .onode--sm { font-size: clamp(0.58rem, 0.95vw, 0.74rem); padding: 0.38rem 0.7rem; }
  .onode__i { font-size: 1.15em; }
  .onode--cobalt { border-color: var(--cobalt); }
  .onode--coral { border-color: var(--coral); }
  .onode--sun { border-color: #e0a400; }
  .onode--acid { border-color: #7a9a00; }
  .onode--lilac { border-color: #9d7bff; }
  .orbit__center {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%) scale(0); opacity: 0; z-index: 2;
    background: var(--ink); color: var(--acid); border-radius: 50%; box-shadow: var(--shadow);
    width: clamp(90px, 11vw, 130px); height: clamp(90px, 11vw, 130px);
    display: grid; place-items: center; font-weight: 700; letter-spacing: 0.08em; font-size: clamp(0.8rem, 1.3vw, 1rem);
  }
  .orbit-on .orbit__center { animation: ocpop 0.5s var(--ease-spring) both; animation-delay: var(--d, 0s); }
  @keyframes ocpop { from { transform: translate(-50%,-50%) scale(0); opacity: 0; } to { transform: translate(-50%,-50%) scale(1); opacity: 1; } }
  .orbit__legend { display: flex; gap: 1.2rem; flex-wrap: wrap; margin-top: 0.6rem; justify-content: center; }
  .orbit__leg { display: inline-flex; align-items: center; gap: 0.45em; font-size: 0.74rem; font-weight: 700; }
  .orbit__leg i { width: 11px; height: 11px; border-radius: 3px; border: 2px solid var(--ink); display: inline-block; }
  .orbit__list { display: none; }
  @media (max-width: 720px) {
    .orbit__stage, .orbit__legend { display: none; }
    .orbit__list { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .orbit__list .tag { box-shadow: var(--shadow-sm); border-width: 2.5px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .orbit-on .onode { animation: opop 0.01s both; }
    .orbit-on .orbit__center { animation-duration: 0.01s; }
  }

  /* academic */
  .acad__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  .acad__item { padding: 1.2rem 1.3rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .acad__t { font-weight: 700; font-size: 1.02rem; }
  .acad__o { font-size: 0.82rem; }
  @media (max-width: 640px) { .acad__grid { grid-template-columns: 1fr; } }

  /* contact */
  .contact {
    background: var(--acid); border-top: var(--bd) solid var(--ink); margin-top: 0;
    min-height: calc(100svh - 58px);
    display: flex; align-items: center; justify-content: center;
    padding-block: clamp(2rem, 4vw, 4rem);
  }
  .contact__title { margin: 0.5rem 0 2rem; }
  .contact__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>

<script>
  import { initMotion } from '../scripts/motion.ts';
  initMotion();

  // skills orbit: pop in when scrolled into view
  const orbit = document.querySelector('[data-orbit]');
  if (orbit) {
    new IntersectionObserver((entries, obs) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          orbit.classList.add('orbit-on');
          obs.disconnect();
        }
      });
    }, { threshold: 0.2 }).observe(orbit);
  }

  // funnel: build in when scrolled into view, reset when fully out (replays like the reference loop)
  const fn = document.querySelector('[data-funnel]');
  if (fn) {
    new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.intersectionRatio >= 0.25) fn.classList.add('funnel-on');
        else if (e.intersectionRatio === 0) fn.classList.remove('funnel-on');
      });
    }, { threshold: [0, 0.25] }).observe(fn);

    // two-way hover sync: slice ↔ its side label
    const pairs = new Map();
    fn.querySelectorAll('[data-band]').forEach((el) => {
      const k = (el as HTMLElement).dataset.band;
      if (!pairs.has(k)) pairs.set(k, []);
      pairs.get(k).push(el);
    });
    pairs.forEach((els) => {
      els.forEach((el: Element) => {
        el.addEventListener('mouseenter', () => els.forEach((e: Element) => e.classList.add('hl')));
        el.addEventListener('mouseleave', () => els.forEach((e: Element) => e.classList.remove('hl')));
      });
    });
  }
</script>
