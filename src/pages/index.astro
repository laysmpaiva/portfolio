---
import Layout from '../layouts/Layout.astro';
import { profile, stats, capabilities, caseStudies, tooling, skills } from '../data/content.ts';
import showcase from '../data/showcase.json';

const fmtSpend = (key: string) => {
  const v = (showcase.spend as Record<string, number | null>)[key];
  if (v == null) return null;
  if (v >= 1_000_000) return '$' + (v / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (v >= 1_000) return '$' + Math.round(v / 1000) + 'K';
  return '$' + Math.round(v);
};
const totalSpend = showcase.totalManagedSpend
  ? '$' + (showcase.totalManagedSpend / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M+'
  : null;
---

<Layout>
  <!-- ================= NAV ================= -->
  <header class="nav">
    <a href="#top" class="nav__logo">
      <span class="nav__mark">L</span>
      <span>Lays Paiva</span>
    </a>
    <nav class="nav__links">
      <a href="#work">Work</a>
      <a href="#tooling">AI&nbsp;Tooling</a>
      <a href="#about">About</a>
      <a href="#contact" class="btn btn--coral nav__cta">Hire me</a>
    </nav>
  </header>

  <!-- ================= HERO ================= -->
  <section id="top" class="hero">
    <div class="wrap hero__inner">
      <div class="hero__text">
        <p class="eyebrow reveal">{profile.role} · for builders</p>

        <h1 class="display hero__name reveal">
          <span>LAYS</span>
          <span>PAIVA<span class="hero__dot">.</span></span>
        </h1>

        <p class="hero__rotor-line reveal">
          Growth for
          <span class="hero__rotor" data-words={JSON.stringify(profile.headlineWords)}><span class="mark">SaaS</span></span>
        </p>

        <p class="hero__tag reveal">{profile.tagline}</p>

        <div class="hero__actions reveal">
          <a href="#work" class="btn">See the numbers ↓</a>
          <a href="#contact" class="btn btn--ghost">Let's talk</a>
        </div>
      </div>

      <!-- scrapbook photo -->
      <div class="hero__photo-wrap reveal">
        <figure class="photo r-2">
          <img src={profile.photo} alt="Lays Paiva" width="520" height="560" loading="eager" onerror="this.onerror=null;this.src='/lays-placeholder.svg'" />
          <figcaption class="hand">Lays — growth, but make it convert ✶</figcaption>
        </figure>
        <span class="tape photo__tape-1 r-1" aria-hidden="true"></span>
        <span class="tape photo__tape-2 r-4" aria-hidden="true"></span>
        <div class="sticker hero__sticker r-4" aria-hidden="true"><span>685K<br>subs<br>scaled ✷</span></div>
        <span class="hero__star" aria-hidden="true">✷</span>
      </div>
    </div>
  </section>

  <!-- ================= MARQUEE ================= -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {Array.from({ length: 2 }).map(() => (
        <span class="marquee__group">
          <b>SaaS</b> ✦ <b>Startups</b> ✦ <b>AI products</b> ✦ <b>Vibe marketing</b> ✦
          <b>Paid acquisition</b> ✦ <b>CAC math</b> ✦ <b>UGC creative</b> ✦
          <b>Conversion-first</b> ✦
        </span>
      ))}
    </div>
  </div>

  <!-- ================= STATS ================= -->
  <section id="impact" class="stats">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">01</span> The receipts</h2>
      <div class="stats__grid">
        {stats.map((s) => (
          <div class={`stat card reveal accent-${s.color}`}>
            <div class="stat__num" data-count={s.value} data-prefix={s.prefix ?? ''} data-suffix={s.suffix ?? ''}>
              {s.prefix ?? ''}{s.value}{s.suffix ?? ''}
            </div>
            <p class="stat__label">{s.label}</p>
            <p class="stat__sub mono muted">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= WORK / CASE STUDIES ================= -->
  <section id="work" class="work">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">02</span> Selected work</h2>
      <p class="section-lead reveal muted">
        Curated to SaaS, startup &amp; AI products. Results are documented; ad spend is
        <strong>managed spend over my time on each account</strong>{totalSpend ? <> — {totalSpend} in total</> : null}, not lifetime account totals.
      </p>

      <div class="work__list">
        {caseStudies.map((c, i) => {
          const spend = fmtSpend(c.spendKey);
          return (
            <article class={`case card reveal accent-${c.accent} ${i % 2 ? 'case--flip' : ''}`}>
              <div class="case__media">
                <div class={`case__visual bg-${c.accent}`} data-client={c.client}>
                  {c.image ? (
                    <figure class="creative">
                      <img src={c.image} alt={`${c.client} ad creative — ${c.adName}`} loading="lazy" width="270" height="480" />
                      <figcaption class="creative__cap mono">{c.adName}</figcaption>
                    </figure>
                  ) : (
                    <>
                      <span class="case__visual-tag mono">{c.category}</span>
                      <span class="case__visual-big">{c.client}</span>
                      {c.adName ? <span class="case__visual-ad mono">▸ top ad: {c.adName}</span> : null}
                    </>
                  )}
                </div>
                <span class="tape case__tape r-3" aria-hidden="true"></span>
              </div>

              <div class="case__body">
                <div class="case__top">
                  <span class="tag">{c.category}</span>
                  <span class="mono muted case__span">{c.span}</span>
                </div>
                <h3 class="case__client">{c.client} <span class="muted case__person">/ {c.person}</span></h3>
                <p class="case__headline">{c.headline}</p>
                <p class="case__text muted">{c.body}</p>

                <div class="case__results">
                  {c.results.map((r) => (
                    <div class="result">
                      <span class="result__v">{r.v}</span>
                      <span class="result__k mono">{r.k}</span>
                      {r.note ? <span class="result__n muted">{r.note}</span> : null}
                    </div>
                  ))}
                </div>

                <div class="case__foot">
                  <span class="sticker case__pill r-2">{c.pill}</span>
                  {spend ? <span class="tag case__spend">▲ {spend} managed</span> : null}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ================= CAPABILITIES ================= -->
  <section id="capabilities" class="caps">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">03</span> How I operate</h2>
      <div class="caps__grid">
        {capabilities.map((c) => (
          <div class={`cap card reveal accent-${c.color}`}>
            <h3 class="cap__title">{c.title}</h3>
            <p class="cap__body muted">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= AI TOOLING ================= -->
  <section id="tooling" class="tooling">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">04</span> I build my own tools</h2>
      <p class="section-lead reveal muted">
        Modern growth isn't just buying media — it's building the system around it. I ship AI agents and automations that make the whole team faster. This is <span class="mark mark--lilac">vibe marketing</span> in practice.
      </p>
      <div class="tooling__grid">
        {tooling.map((t) => (
          <div class="tool card reveal">
            <span class="tag tool__tag">{t.tag}</span>
            <h3 class="tool__name">{t.name}</h3>
            <p class="tool__desc muted">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= ABOUT ================= -->
  <section id="about" class="about">
    <div class="wrap about__inner">
      <div class="about__col reveal">
        <h2 class="section-h"><span class="num">05</span> About</h2>
        <p class="about__lead">{profile.blurb}</p>
        <p class="muted about__loc mono">{profile.location}</p>
      </div>
      <div class="about__skills reveal">
        {skills.map((s, i) => (
          <span class={`tag skill r-${(i % 4) + 1}`}>{s}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= CONTACT ================= -->
  <section id="contact" class="contact">
    <div class="wrap center">
      <p class="eyebrow reveal">{profile.available ? '◉ open to SaaS / startup roles' : 'Get in touch'}</p>
      <h2 class="display contact__title reveal">LET'S<br>GROW<br>SOMETHING</h2>
      <div class="contact__actions reveal">
        <a href={`mailto:${profile.email}`} class="btn btn--cobalt">Email me ✉</a>
        {profile.socials.filter((s) => s.label === 'LinkedIn').map((s) => (
          <a href={s.href} class="btn btn--ghost">LinkedIn ↗</a>
        ))}
      </div>
    </div>
    <footer class="footer">
      <span class="mono">© {new Date().getFullYear()} Lays Paiva</span>
      <span class="mono muted">Built with Astro + GSAP · neobrutalist scrapbook</span>
    </footer>
  </section>
</Layout>

<style>
  /* ---------- NAV ---------- */
  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: var(--paper);
    border-bottom: var(--bd) solid var(--ink);
  }
  .nav__logo { display: flex; align-items: center; gap: 0.55rem; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
  .nav__mark {
    display: grid; place-items: center; width: 30px; height: 30px;
    background: var(--acid); border: 2.5px solid var(--ink); border-radius: 6px;
    font-weight: 700; box-shadow: var(--shadow-sm);
  }
  .nav__links { display: flex; align-items: center; gap: clamp(0.8rem, 2.5vw, 1.8rem); font-weight: 600; }
  .nav__links a { text-decoration: none; }
  .nav__links > a:not(.btn):hover { text-decoration: underline 2px; text-underline-offset: 4px; }
  .nav__cta { padding: 0.5em 1em; font-size: 0.8rem; }
  @media (max-width: 620px) {
    .nav__links a:not(.nav__cta) { display: none; }
  }

  /* ---------- HERO ---------- */
  .hero { padding-top: clamp(2.5rem, 6vw, 4.5rem); padding-bottom: clamp(2rem, 5vw, 4rem); }
  .hero__inner {
    position: relative;
    display: grid; grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center;
  }
  .hero__name { margin: 0.4rem 0 0.8rem; font-size: clamp(3.4rem, 10vw, 8rem); }
  .hero__name > span { display: block; }
  .hero__dot { color: var(--coral); }
  .hero__rotor-line {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.3em;
    font-size: clamp(1.5rem, 3.6vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em;
    text-transform: uppercase; margin-bottom: 1.1rem;
  }
  .hero__rotor { display: inline-block; min-width: 4.5ch; }
  .hero__tag { max-width: 38ch; font-size: clamp(1.05rem, 2.2vw, 1.4rem); font-weight: 500; line-height: 1.3; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 1.8rem; }

  /* photo */
  .hero__photo-wrap { position: relative; justify-self: center; }
  .photo {
    margin: 0; background: var(--paper-2);
    border: var(--bd) solid var(--ink); border-radius: var(--radius);
    box-shadow: var(--shadow-lg); padding: 12px 12px 0;
    width: min(80vw, 360px);
  }
  .photo img {
    display: block; width: 100%; height: auto; aspect-ratio: 1 / 1;
    object-fit: cover; border: 2px solid var(--ink);
    /* graceful look if the file isn't dropped yet */
    background: repeating-linear-gradient(45deg, var(--lilac), var(--lilac) 12px, var(--paper-2) 12px, var(--paper-2) 24px);
  }
  .photo figcaption {
    font-size: 1.35rem; color: var(--ink); text-align: center;
    padding: 0.35rem 0 0.6rem;
  }
  .photo__tape-1 { top: -16px; left: 30px; }
  .photo__tape-2 { bottom: 38px; right: -22px; }
  .hero__sticker {
    position: absolute; bottom: -22px; left: -28px;
    width: 110px; height: 110px; font-size: 0.78rem; line-height: 1.15;
    background: var(--coral); color: var(--paper-2); z-index: 6;
  }
  .hero__star { position: absolute; top: -22px; right: 8px; font-size: 2.2rem; color: var(--sun); z-index: 6; }
  @media (max-width: 820px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__photo-wrap { order: -1; margin-bottom: 0.5rem; }
    .photo { width: min(72vw, 280px); }
    .hero__sticker { width: 86px; height: 86px; font-size: 0.62rem; bottom: -16px; left: -10px; }
  }

  /* ---------- MARQUEE ---------- */
  .marquee {
    overflow: hidden; white-space: nowrap;
    border-block: var(--bd) solid var(--ink);
    background: var(--ink); color: var(--paper);
    padding: 0.55rem 0;
  }
  .marquee__track { display: inline-flex; will-change: transform; animation: scroll 26s linear infinite; }
  .marquee__group { font-family: var(--font-mono); font-size: 1rem; padding-right: 1ch; letter-spacing: 0.04em; }
  .marquee__group b { color: var(--acid); }
  @keyframes scroll { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }

  /* ---------- section headings ---------- */
  .section-h {
    font-size: clamp(1.8rem, 5vw, 3.2rem); text-transform: uppercase;
    display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 1.2rem;
  }
  .section-h .num { font-family: var(--font-mono); font-size: 0.9rem; color: var(--coral); border: 2px solid var(--ink); border-radius: 999px; padding: 0.2em 0.7em; }
  .section-lead { max-width: 56ch; font-size: 1.05rem; margin-bottom: 2.5rem; }

  /* ---------- STATS ---------- */
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; }
  .stat { padding: 1.6rem 1.4rem; }
  .stat__num { font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; }
  .stat__label { margin-top: 0.6rem; font-weight: 600; font-size: 0.98rem; }
  .stat__sub { font-size: 0.78rem; margin-top: 0.3rem; }
  @media (max-width: 900px) { .stats__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .stats__grid { grid-template-columns: 1fr; } }

  /* ---------- WORK ---------- */
  .work__list { display: grid; gap: 2.4rem; }
  .case { display: grid; grid-template-columns: 0.85fr 1.15fr; overflow: hidden; }
  .case--flip .case__media { order: 2; }
  .case__media { position: relative; min-height: 280px; border-right: var(--bd) solid var(--ink); }
  .case--flip .case__media { border-right: none; border-left: var(--bd) solid var(--ink); }
  .case__visual {
    width: 100%; height: 100%; min-height: 280px;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 1.2rem; color: var(--ink);
    background-image: radial-gradient(rgba(20,18,16,0.16) 1.4px, transparent 1.4px);
    background-size: 16px 16px;
  }
  .case__visual-tag { font-size: 0.72rem; align-self: flex-start; background: var(--paper-2); border: 2px solid var(--ink); padding: 0.2em 0.6em; border-radius: 999px; }
  .case__visual-big { font-size: clamp(1.6rem, 3.5vw, 2.6rem); font-weight: 700; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.95; }
  .case__visual-ad { font-size: 0.72rem; background: var(--ink); color: var(--paper-2); padding: 0.3em 0.6em; border-radius: 4px; align-self: flex-start; }
  /* pinned vertical ad creative */
  .case__visual:has(.creative) { align-items: center; justify-content: center; padding: 1.5rem 1rem; }
  .creative { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; transform: rotate(-1.5deg); }
  .creative img {
    display: block; width: auto; height: clamp(240px, 38vh, 380px); max-width: 100%;
    border: var(--bd) solid var(--ink); border-radius: 3px; box-shadow: var(--shadow);
    background: var(--paper-2);
  }
  .creative__cap {
    font-size: 0.68rem; background: var(--paper-2); border: 2px solid var(--ink);
    padding: 0.25em 0.6em; border-radius: 999px; text-align: center; max-width: 100%;
  }
  .case__tape { top: 14px; right: 14px; }
  .case__body { padding: 1.6rem 1.7rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .case__top { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .case__span { font-size: 0.74rem; }
  .case__client { font-size: clamp(1.3rem, 3vw, 1.9rem); }
  .case__person { font-size: 0.7em; font-weight: 500; }
  .case__headline { font-weight: 600; font-size: 1.12rem; line-height: 1.25; }
  .case__text { font-size: 0.95rem; }
  .case__results { display: flex; flex-wrap: wrap; gap: 1.4rem; margin-top: 0.5rem; padding-top: 1rem; border-top: 2px dashed var(--ink); }
  .result { display: flex; flex-direction: column; }
  .result__v { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.02em; }
  .result__k { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .result__n { font-size: 0.72rem; }
  .case__foot { margin-top: auto; padding-top: 1rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; justify-content: space-between; }
  .case__pill { border-radius: 4px; padding: 0.45em 0.8em; font-size: 0.72rem; max-width: 60%; }
  .case__spend { background: var(--ink); color: var(--acid); border-color: var(--ink); }
  @media (max-width: 820px) {
    .case, .case--flip { grid-template-columns: 1fr; }
    .case__media, .case--flip .case__media { order: 0; border-right: none; border-left: none; border-bottom: var(--bd) solid var(--ink); min-height: 180px; }
    .case__visual { min-height: 180px; }
  }

  /* ---------- CAPABILITIES ---------- */
  .caps__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; }
  .cap { padding: 1.5rem 1.3rem; }
  .cap__title { font-size: 1.25rem; margin-bottom: 0.6rem; }
  .cap__body { font-size: 0.92rem; }
  @media (max-width: 900px) { .caps__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .caps__grid { grid-template-columns: 1fr; } }

  /* ---------- TOOLING ---------- */
  .tooling { background: var(--ink); color: var(--paper); }
  .tooling .section-h, .tooling .section-lead { color: var(--paper); }
  .tooling .section-lead.muted { color: rgba(242,236,217,0.7); }
  .tooling .section-h .num { color: var(--acid); border-color: var(--paper); }
  .tooling__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .tool { background: #1f1c19; color: var(--paper); border-color: var(--paper); box-shadow: 6px 6px 0 var(--acid); padding: 1.4rem; }
  .tool__name { font-size: 1.2rem; margin: 0.7rem 0 0.5rem; }
  .tool__desc { font-size: 0.92rem; color: rgba(242,236,217,0.72); }
  .tool__tag { background: var(--acid); color: var(--ink); }
  @media (max-width: 700px) { .tooling__grid { grid-template-columns: 1fr; } }

  /* ---------- ABOUT ---------- */
  .about__inner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2.5rem; align-items: start; }
  .about__lead { font-size: clamp(1.2rem, 2.6vw, 1.7rem); font-weight: 500; line-height: 1.3; margin: 0.5rem 0 1rem; }
  .about__loc { font-size: 0.85rem; }
  .about__skills { display: flex; flex-wrap: wrap; gap: 0.7rem; align-content: flex-start; }
  .skill { background: var(--paper-2); box-shadow: var(--shadow-sm); }
  @media (max-width: 760px) { .about__inner { grid-template-columns: 1fr; } }

  /* ---------- CONTACT ---------- */
  .contact { background: var(--acid); border-top: var(--bd) solid var(--ink); }
  .contact__title { margin: 0.5rem 0 2rem; }
  .contact__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .footer {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    border-top: var(--bd) solid var(--ink); margin-top: clamp(3rem, 7vw, 5rem);
    padding: 1.2rem clamp(1rem,4vw,2.5rem); font-size: 0.8rem;
  }

  /* ---------- accents ---------- */
  .accent-acid   { border-top: 8px solid var(--acid); }
  .accent-coral  { border-top: 8px solid var(--coral); }
  .accent-cobalt { border-top: 8px solid var(--cobalt); }
  .accent-sun    { border-top: 8px solid var(--sun); }
  .accent-lilac  { border-top: 8px solid var(--lilac); }
  .bg-acid { background-color: var(--acid); }
  .bg-coral { background-color: var(--coral); color: var(--paper-2) !important; }
  .bg-cobalt { background-color: var(--cobalt); color: var(--paper-2) !important; }
  .bg-sun { background-color: var(--sun); }
  .bg-lilac { background-color: var(--lilac); }
</style>

<script>
  import { initMotion } from '../scripts/motion.ts';
  initMotion();
</script>
