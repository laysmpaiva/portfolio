---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { profile, stats, caseStudies, tooling, feedbacks } from '../data/content.ts';
import showcase from '../data/showcase.json';

const fmtSpend = (key: string) => {
  const v = (showcase.spend as Record<string, number | null>)[key];
  if (v == null) return null;
  if (v >= 1_000_000) return '$' + (v / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (v >= 1_000) return '$' + Math.round(v / 1000) + 'K';
  return '$' + Math.round(v);
};
const totalSpend = showcase.totalManagedSpend
  ? '$' + (showcase.totalManagedSpend / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M+'
  : null;
---

<Layout>
  <Nav active="home" />

  <!-- ================= HERO ================= -->
  <section id="top" class="hero">
    <div class="wrap hero__inner">
      <div class="hero__text">
        <p class="eyebrow reveal">{profile.role} · for builders</p>
        <h1 class="display hero__name reveal">
          <span>LAYS</span>
          <span>PAIVA<span class="hero__dot">.</span></span>
        </h1>
        <p class="hero__rotor-line reveal">
          Growth for
          <span class="hero__rotor" data-words={JSON.stringify(profile.headlineWords)}><span>SaaS</span></span>
          <svg class="scribble hero__squiggle" viewBox="0 0 320 22" width="320" height="22" aria-hidden="true">
            <path class="draw" d="M4 13 q 36 -12 72 0 t 72 0 t 72 0 t 72 -2" stroke-width="6" />
          </svg>
        </p>
        <p class="hero__tag reveal">{profile.tagline}</p>
        <ul class="hero__facts reveal">
          <li><b>Now:</b> Growth Manager @ The Feed Media</li>
          <li><b>Focus:</b> growing products end to end: SaaS, AI, media, ecommerce &amp; creator brands</li>
          <li><b>Edge:</b> full-funnel execution + AI systems I build myself</li>
        </ul>
        <div class="hero__actions reveal">
          <a href="#work" class="btn">See the numbers ↓</a>
          <a href="/about" class="btn btn--cobalt">My career, day-to-day &amp; skills →</a>
        </div>
      </div>
      <div class="hero__photo-wrap reveal">
        <span class="hero__vlabel hand">watch first ↓</span>
        <div class="hero__frame">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${profile.youtubeId}`}
            title="Lays Paiva, intro"
            loading="eager"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
        <span class="hero__vnote hand">↑ yes, that's me on camera. I do that.</span>
        <!-- floating sticker badges -->
        <span class="hbadge hbadge--a floaty" style="--rot:-7deg" aria-hidden="true">$5.2M managed ✷</span>
        <span class="hbadge hbadge--b floaty floaty--b pulse" style="--rot:6deg" aria-hidden="true">◉ open to work</span>
        <svg class="scribble hero__star-doodle floaty" viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
          <path class="draw" d="M20 3 L24 16 L37 20 L24 24 L20 37 L16 24 L3 20 L16 16 Z" stroke-width="4" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ================= MARQUEE ================= -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {Array.from({ length: 6 }).map(() => (
        <span class="marquee__group">
          <b>Newsletters</b> ✦ <b>SaaS</b> ✦ <b>Startups</b> ✦ <b>AI products</b> ✦ <b>Media &amp; creators</b> ✦ <b>DTC &amp; ecommerce</b> ✦
          <b>Full-funnel growth</b> ✦ <b>Positioning &amp; offers</b> ✦ <b>Lifecycle email</b> ✦ <b>Paid acquisition</b> ✦ <b>Vibe marketing</b> ✦
        </span>
      ))}
    </div>
  </div>

  <!-- ================= AI TOOLING ================= -->
  <section id="tooling" class="tooling">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">01</span> I build my own tools</h2>
      <p class="section-lead reveal muted">
        Buying media is the easy part; the system around it is where growth actually compounds. I ship AI agents and automations that make the whole team faster. This is <span class="grad">vibe marketing</span> in practice.
      </p>
      <div class="tooling__grid">
        {tooling.map((t) => (
          <a href={`/tooling/${t.slug}`} class="tool card reveal--pop">
            <div class="tool__top">
              <span class="tag tool__tag">{t.tag}</span>
              {t.delta ? <span class="tool__delta mono">{t.delta}</span> : null}
            </div>
            <h3 class="tool__name">{t.name}</h3>
            <p class="tool__desc muted">{t.desc}</p>
            <span class="tool__more mono">How it works →</span>
          </a>
        ))}
      </div>
      <p class="tooling__ps reveal">Oh, and this website? Also <span class="grad">Claude Code</span>. Designed, built and maintained by me, prompt by prompt.</p>
    </div>
  </section>

  <!-- ================= MAIN PROJECTS ================= -->
  <section id="work" class="work">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">02</span> Main projects</h2>
      <p class="section-lead reveal muted">
        SaaS, AI, media, creator &amp; DTC products I've scaled. Results documented, receipts included{totalSpend ? <>, {totalSpend} managed across my career</> : null}. <span class="mono">Click any card →</span>
      </p>

      <div class="work__list">
        {caseStudies.map((c, i) => {
          const spend = fmtSpend(c.spendKey);
          return (
            <a href={`/work/${c.id}`} class={`case card reveal accent-${c.accent} ${i % 2 ? 'case--flip' : ''}`}>
              <div class="case__media">
                <div class={`case__visual bg-${c.accent}`}>
                  {c.face ? (
                    <img class="cv-face" src={c.face} alt={c.person} loading="lazy" width="180" height="180" />
                  ) : c.logo ? (
                    <img class="cv-logo" src={c.logo} alt={`${c.client} logo`} loading="lazy" />
                  ) : c.emoji ? (
                    <span class="cv-emoji" aria-hidden="true">{c.emoji}</span>
                  ) : null}
                  <span class="cv-word">{c.client}</span>
                  {c.person && !c.kind ? <span class="cv-person mono">{c.person}</span> : null}
                </div>
              </div>
              <div class="case__body">
                <div class="case__top">
                  <span class="tag">{c.category}</span>
                </div>
                <h3 class="case__client">{c.client} <span class="muted case__person">/ {c.person}</span></h3>
                <p class="case__headline">{c.headline}</p>
                <p class="case__text muted">{c.body}</p>
                <div class="case__results">
                  {c.results.map((r) => (
                    <div class="result">
                      <span class="result__v">{r.v}</span>
                      <span class="result__k mono">{r.k}{r.note ? <span class="result__n muted"> · {r.note}</span> : null}</span>
                    </div>
                  ))}
                </div>
                <div class="case__foot">
                  <span class="sticker case__pill r-2">{c.pill}</span>
                  <span class="case__more mono">{spend ? <span class="case__spend">▲ {spend} managed</span> : null} View case →</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ================= STATS ================= -->
  <section id="impact" class="stats">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">03</span> The receipts</h2>
      <div class="stats__grid">
        {stats.map((s) => (
          <div class={`stat card reveal--pop accent-${s.color}`}>
            <div class="stat__num grad-ink" data-count={s.value} data-prefix={s.prefix ?? ''} data-suffix={s.suffix ?? ''}>
              {s.prefix ?? ''}{s.value}{s.suffix ?? ''}
            </div>
            <p class="stat__label">{s.label}</p>
            <p class="stat__sub mono muted">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= FEEDBACKS ================= -->
  <section id="feedbacks" class="fb">
    <div class="wrap">
      <h2 class="section-h reveal"><span class="num">04</span> What people say</h2>
      <p class="fb__label fb__label--first eyebrow reveal">◆ Verified client reviews</p>
      <div class="fb__shots">
        {feedbacks.screenshots.map((src, i) => (
          <figure class={`fb__shot reveal--pop r-${(i % 4) + 1}`}>
            <img src={src} alt="Client review" loading="lazy" width="480" height="270" />
          </figure>
        ))}
      </div>
      <p class="fb__label eyebrow reveal">◆ Straight from Slack</p>
      <div class="fb__quotes">
        {feedbacks.quotes.map((f) => (
          <blockquote class={`fb__q card reveal--pop accent-${f.color}`}>
            <p class="fb__text">“{f.quote}”</p>
            <footer class="fb__who mono">{f.who} <span class="muted">· {f.ctx}</span></footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ================= CONTACT ================= -->
  <section id="contact" class="contact">
    <div class="wrap center">
      <p class="eyebrow reveal">{profile.available ? '◉ open to growth & marketing lead roles' : 'Get in touch'}</p>
      <h2 class="display contact__title reveal">LET'S<br>GROW<br>SOMETHING</h2>
      <div class="contact__actions reveal">
        <a href={`mailto:${profile.email}`} class="btn btn--cobalt">Email me ✉</a>
        <a href={profile.socials[0].href} class="btn btn--ghost">LinkedIn ↗</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero { padding-top: clamp(2.5rem, 6vw, 4.5rem); padding-bottom: clamp(2rem, 5vw, 4rem); }
  .hero__inner { position: relative; display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center; }
  .hero__name { margin: 0.4rem 0 0.8rem; font-size: clamp(3.4rem, 10vw, 8rem); }
  .hero__name > span { display: block; }
  .hero__dot { color: var(--coral); }
  .hero__rotor-line { position: relative; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.3em; font-size: clamp(1.5rem, 3.6vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em; text-transform: uppercase; margin-bottom: 2.4rem; }
  .hero__rotor { display: inline-block; min-width: 4.5ch; }
  .hero__rotor span { background-image: linear-gradient(var(--acid), var(--acid)); background-repeat: no-repeat; background-size: 100% 42%; background-position: 0 82%; padding: 0 .08em; }
  .hero__squiggle { position: absolute; left: 0; bottom: -18px; width: clamp(220px, 60%, 320px); height: 22px; color: var(--coral); }
  .hero__tag { max-width: 38ch; font-size: clamp(1.05rem, 2.2vw, 1.4rem); font-weight: 500; line-height: 1.3; }
  .hero__facts { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.4rem; }
  .hero__facts li { position: relative; padding-left: 1.5rem; font-size: 0.96rem; }
  .hero__facts li::before { content: "▸"; position: absolute; left: 0; color: var(--coral); font-weight: 700; }
  .hero__facts b { font-weight: 700; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 1.6rem; }
  .hero__photo-wrap { position: relative; justify-self: stretch; width: 100%; max-width: 720px; }
  .hero__vlabel { position: absolute; top: -40px; right: 14px; font-size: 1.7rem; color: var(--cobalt); transform: rotate(4deg); z-index: 3; }
  .hero__vnote { display: block; margin-top: 0.9rem; padding-left: 0.4rem; text-align: left; max-width: 60%; font-size: 1.45rem; color: var(--coral); transform: rotate(-2deg); }
  .hero__frame { border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow-lg); overflow: hidden; aspect-ratio: 16 / 9; background: var(--ink); }
  .hero__frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  .hbadge { position: absolute; z-index: 6; font-family: var(--font-mono); font-weight: 700; font-size: 0.74rem; padding: 0.5em 0.85em; border: var(--bd) solid var(--ink); border-radius: 999px; box-shadow: var(--shadow-sm); white-space: nowrap; }
  .hbadge--a { top: -16px; left: -20px; background: var(--sun); }
  .hbadge--b { bottom: -16px; right: -14px; background: var(--acid); color: var(--ink); }
  .hero__star-doodle { top: -34px; left: 42%; color: var(--coral); }
  @media (max-width: 820px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__photo-wrap { order: -1; margin-bottom: 0.8rem; max-width: none; }
    .hero__vlabel { display: none; }
    .hbadge--a { left: -6px; } .hbadge--b { right: -6px; }
  }

  /* ---------- MARQUEE ---------- */
  .marquee { overflow: hidden; white-space: nowrap; border-block: var(--bd) solid var(--ink); background: var(--ink); color: var(--paper); padding: 0.55rem 0; }
  .marquee__track { display: inline-flex; will-change: transform; animation: scroll 26s linear infinite; }
  .marquee__group { font-family: var(--font-mono); font-size: 1rem; padding-right: 1ch; letter-spacing: 0.04em; }
  .marquee__group b { color: var(--acid); }
  @keyframes scroll { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }

  /* ---------- STATS ---------- */
  .stats__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.4rem; }
  .stat { padding: 1.6rem 1.4rem; }
  .stat__num { font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; }
  .stat__label { margin-top: 0.6rem; font-weight: 600; font-size: 0.98rem; }
  .stat__sub { font-size: 0.78rem; margin-top: 0.3rem; }
  @media (max-width: 900px) { .stats__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .stats__grid { grid-template-columns: 1fr; } }

  /* ---------- WORK ---------- */
  .work__list { display: grid; gap: 2.4rem; }
  .case { display: grid; grid-template-columns: 0.85fr 1.15fr; overflow: hidden; text-decoration: none; color: inherit; transition: transform .22s var(--ease-out), box-shadow .25s ease; }
  .case:hover { transform: translate(-3px,-6px); box-shadow: var(--shadow-lg), 0 22px 44px rgba(20,18,16,.18); }
  .case--flip .case__media { order: 2; }
  .case__media { position: relative; min-height: 280px; border-right: var(--bd) solid var(--ink); }
  .case--flip .case__media { border-right: none; border-left: var(--bd) solid var(--ink); }
  .case__visual { width: 100%; height: 100%; min-height: 280px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; padding: 1.6rem; text-align: center; }
  .cv-face { width: clamp(120px, 15vw, 172px); height: clamp(120px, 15vw, 172px); border-radius: 50%; object-fit: cover; border: var(--bd) solid var(--ink); box-shadow: var(--shadow); background: var(--paper-2); }
  .cv-logo { max-width: 78%; max-height: 96px; width: auto; height: auto; background: var(--paper-2); border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow); padding: 0.9rem 1.3rem; box-sizing: border-box; object-fit: contain; }
  .cv-emoji { font-size: clamp(3rem, 7vw, 5rem); line-height: 1; }
  .cv-word { font-size: clamp(1.7rem, 3.6vw, 2.6rem); font-weight: 700; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.92; }
  .cv-person { font-size: 0.74rem; font-weight: 700; background: var(--paper-2); color: var(--ink); border: 2px solid var(--ink); padding: 0.25em 0.7em; border-radius: 999px; }
  .case__body { padding: 1.6rem 1.7rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .case__top { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .case__client { font-size: clamp(1.3rem, 3vw, 1.9rem); }
  .case__person { font-size: 0.7em; font-weight: 500; }
  .case__headline { font-weight: 600; font-size: 1.12rem; line-height: 1.25; }
  .case__text { font-size: 0.95rem; }
  .case__results { display: flex; flex-wrap: wrap; gap: 1.4rem; margin-top: 0.5rem; padding-top: 1rem; border-top: 2px dashed var(--ink); }
  .result { display: flex; flex-direction: column; gap: 0.25rem; }
  .result__v { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; }
  .result__k { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.45; }
  .result__n { font-size: inherit; text-transform: none; letter-spacing: 0.02em; }
  .case__foot { margin-top: auto; padding-top: 1rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; justify-content: space-between; }
  .case__pill { border-radius: 4px; padding: 0.45em 0.8em; font-size: 0.72rem; max-width: 55%; }
  .case__more { font-size: 0.78rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.7rem; }
  .case__spend { background: var(--ink); color: var(--acid); border: 2px solid var(--ink); padding: 0.25em 0.6em; border-radius: 999px; }
  @media (max-width: 820px) {
    .case, .case--flip { grid-template-columns: 1fr; }
    .case__media, .case--flip .case__media { order: 0; border: none; border-bottom: var(--bd) solid var(--ink); min-height: 240px; }
  }

  /* ---------- FEEDBACKS ---------- */
  .fb__quotes { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .fb__q { padding: 1.5rem 1.5rem 1.2rem; margin: 0; }
  .fb__text { font-size: 1.15rem; font-weight: 500; line-height: 1.35; }
  .fb__who { margin-top: 0.9rem; font-size: 0.82rem; font-weight: 700; }
  .fb__label { margin: 2.6rem 0 1.1rem; }
  .fb__label--first { margin-top: 0; }
  .fb__shots { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.6rem; }
  .fb__shot { margin: 0; border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow); background: var(--paper-2); padding: 10px; overflow: hidden; }
  .fb__shot img { display: block; width: 100%; height: auto; border-radius: 2px; }
  @media (max-width: 760px) { .fb__quotes { grid-template-columns: 1fr; } .fb__shots { grid-template-columns: 1fr; } }

  /* ---------- TOOLING ---------- */
  .tooling { background: var(--ink); color: var(--paper); }
  .tooling .section-h, .tooling .section-lead { color: var(--paper); }
  .tooling .section-lead.muted { color: rgba(242,236,217,0.7); }
  .tooling .section-h .num { color: var(--acid); border-color: var(--paper); }
  .tooling__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .tool { display: block; background: #1f1c19; color: var(--paper); border-color: var(--paper); box-shadow: 6px 6px 0 var(--acid); padding: 1.4rem; text-decoration: none; transition: transform .22s var(--ease-out), box-shadow .25s ease; }
  .tool:hover { transform: translate(-3px,-6px); box-shadow: 10px 10px 0 var(--acid), 0 22px 44px rgba(0,0,0,.5); }
  .tool__top { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; }
  .tool__delta { font-size: 0.74rem; font-weight: 700; color: var(--acid); border: 2px dashed rgba(201,242,39,0.55); border-radius: 999px; padding: 0.2em 0.7em; }
  .tool__name { font-size: 1.2rem; margin: 0.7rem 0 0.5rem; }
  .tool__desc { font-size: 0.92rem; color: rgba(242,236,217,0.72); }
  .tool__tag { background: var(--acid); color: var(--ink); }
  .tool__more { display: inline-block; margin-top: 0.9rem; font-size: 0.78rem; font-weight: 700; color: var(--acid); }
  .tooling__ps { margin-top: 2rem; font-size: clamp(1.05rem, 2vw, 1.3rem); font-weight: 600; color: var(--paper); }
  @media (max-width: 700px) { .tooling__grid { grid-template-columns: 1fr; } }

  /* ---------- CONTACT ---------- */
  .contact {
    background: var(--acid); border-top: var(--bd) solid var(--ink);
    min-height: calc(100svh - 58px);
    display: flex; align-items: center; justify-content: center;
    padding-block: clamp(2rem, 4vw, 4rem);
  }
  .contact__title { margin: 0.5rem 0 2rem; }
  .contact__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>

<script>
  import { initMotion } from '../scripts/motion.ts';
  initMotion();
</script>
