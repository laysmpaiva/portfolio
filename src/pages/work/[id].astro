---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { caseStudies, method } from '../../data/content.ts';

export function getStaticPaths() {
  // Own-product pages (VSL Production, Email Funnels) have dedicated pages.
  const clients = caseStudies.filter((c) => !c.kind);
  return clients.map((c, i) => ({
    params: { id: c.id },
    props: {
      c,
      next: clients[(i + 1) % clients.length],
    },
  }));
}

const { c, next } = Astro.props;
---

<Layout title={`${c.client} · Lays Paiva`} description={c.headline}>
  <Nav active="work" />

  <article class="cs">
    <!-- header -->
    <header class={`cs__head bg-${c.accent}`}>
      <div class="wrap">
        <a href="/#work" class="cs__back mono">← Back to work</a>
        <div class="cs__head-grid">
          <div>
            <span class="tag cs__cat">{c.category}</span>
            <h1 class="display cs__title">{c.client}</h1>
            <p class="cs__person mono">{c.person}</p>
            <p class="cs__headline">{c.headline}</p>
            <p class="cs__intro">{c.body}</p>
          </div>
          <figure class="cs__hero-shot">
            {c.face ? (
              <img class="cs__hero-face r-2" src={c.face} alt={c.person} width="240" height="240" loading="eager" />
            ) : c.logo ? (
              <img class="cs__hero-logo r-2" src={c.logo} alt={`${c.client} logo`} loading="eager" />
            ) : null}
          </figure>
        </div>
      </div>
    </header>

    <!-- context + what I did -->
    <section class="cs__body wrap">
      <div class="cs__cols">
        <div class="reveal">
          <h2 class="cs__h">The brief</h2>
          <p class="cs__ctx">{c.context}</p>
        </div>
        <div class="reveal">
          <h2 class="cs__h">What I did</h2>
          <ul class="cs__did">
            {c.work.map((w) => <li>{w}</li>)}
          </ul>
        </div>
      </div>

      <!-- metrics -->
      <h2 class="cs__h reveal">The numbers</h2>
      {c.spendKey ? <p class="cs__note mono muted reveal">Managed ad spend is windowed to my time on the account, not the lifetime account total.</p> : null}
      <div class="cs__metrics">
        {c.metrics.map((m) => (
          <div class="metric card reveal--pop">
            <span class="metric__v">{m.v}</span>
            <span class="metric__k mono">{m.k}{m.note ? <span class="metric__n muted"> · {m.note}</span> : null}</span>
          </div>
        ))}
      </div>

      <!-- how the winning ad got made (ByteByteGo only) -->
      {c.id === 'bytebytego' ? (
        <div class="method">
          <h2 class="cs__h reveal">How the winning ad got made</h2>
          <p class="method__lead muted reveal">{method.lead}</p>
          <div class="method__grid">
            <ol class="method__steps">
              {method.steps.map((s) => (
                <li class="mstep reveal">
                  <span class="mstep__n mono">{s.n}</span>
                  <div>
                    <h3 class="mstep__t">{s.t}</h3>
                    <p class="mstep__d muted">{s.d}</p>
                  </div>
                </li>
              ))}
            </ol>
            <figure class="method__ad reveal">
              <img src={method.example.img} alt={`${method.example.client} winning ad`} width="320" height="569" loading="lazy" />
              <span class="sticker method__sticker r-2">{method.example.sticker}</span>
              <figcaption class="hand method__cap">{method.example.caption}</figcaption>
            </figure>
          </div>
        </div>
      ) : null}

      <!-- ads -->
      {c.media && c.media.length ? (
        <>
          <h2 class="cs__h reveal">The ads</h2>
          <div class="cs__gallery">
            {c.media.map((g) => (
              <figure class="ad reveal--pop">
                {g.video ? (
                  <video src={g.src} poster={g.poster || undefined} controls playsinline preload="metadata"></video>
                ) : (
                  <img src={g.src} alt={`${c.client} ad`} loading="lazy" width="300" height="533" />
                )}
              </figure>
            ))}
          </div>
        </>
      ) : null}
    </section>

    <!-- next -->
    <a href={`/work/${next.id}`} class={`cs__next bg-${next.accent}`}>
      <div class="wrap cs__next-inner">
        <span class="mono">Next project</span>
        <span class="cs__next-name">{next.client} →</span>
      </div>
    </a>
  </article>

  <Footer />
</Layout>

<style>
  .cs__head { border-bottom: var(--bd) solid var(--ink); padding-block: clamp(1.2rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem); }
  .cs__back { display: block; width: fit-content; font-weight: 700; text-decoration: none; margin: 0.6rem 0 0.8rem; padding: 0.4em 0.8em; border: 2px solid var(--ink); border-radius: 999px; background: var(--paper-2); color: var(--ink); }
  .cs__head-grid { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 2rem; align-items: center; }
  .cs__cat { display: block; width: fit-content; font-size: 1rem; font-weight: 700; padding: 0.4em 0.8em; border: 2px solid var(--ink); background: var(--pink); color: var(--ink); box-shadow: var(--shadow-sm); }
  .cs__title { font-size: clamp(2.6rem, 8vw, 6rem); margin: 0.6rem 0 0.4rem; text-transform: uppercase; }
  .cs__person { font-weight: 700; font-size: 0.9rem; }
  .cs__headline { font-size: clamp(1.2rem, 2.6vw, 1.7rem); font-weight: 600; line-height: 1.25; margin-top: 1rem; max-width: 30ch; }
  .cs__intro { margin-top: 1rem; max-width: 52ch; font-size: 1.02rem; line-height: 1.45; }
  .cs__hero-shot { margin: 0; justify-self: center; }
  .cs__hero-face { width: clamp(170px, 24vw, 260px); height: clamp(170px, 24vw, 260px); border-radius: 50%; object-fit: cover; border: var(--bd) solid var(--ink); box-shadow: var(--shadow-lg); background: var(--paper-2); display: block; }
  .cs__hero-logo { max-width: 280px; max-height: 150px; background: var(--paper-2); border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow-lg); padding: 1.4rem 1.8rem; box-sizing: border-box; object-fit: contain; display: block; }
  @media (max-width: 760px) { .cs__head-grid { grid-template-columns: 1fr; } .cs__hero-shot { order: -1; } }

  .cs__body { padding-block: clamp(2.5rem, 6vw, 5rem); }
  .cs__cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; margin-bottom: 3.5rem; }
  .cs__h { font-size: clamp(1.4rem, 3.5vw, 2.2rem); text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: baseline; gap: 0.7rem; }
  .cs__ctx { font-size: 1.05rem; line-height: 1.5; }
  .cs__did { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }
  .cs__did li { position: relative; padding-left: 1.6rem; font-size: 0.98rem; line-height: 1.4; }
  .cs__did li::before { content: "▸"; position: absolute; left: 0; color: var(--coral); font-weight: 700; }
  @media (max-width: 760px) { .cs__cols { grid-template-columns: 1fr; gap: 1.8rem; } }

  .cs__note { font-size: 0.78rem; margin: -0.5rem 0 1.2rem; }
  .cs__metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-bottom: 3.5rem; }
  .metric { padding: 1.3rem 1.2rem; display: flex; flex-direction: column; justify-content: center; gap: 0.45rem; }
  .metric__v { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; }
  .metric__k { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.5; }
  .metric__n { font-size: inherit; text-transform: none; letter-spacing: 0.02em; }
  @media (max-width: 700px) { .cs__metrics { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 420px) { .cs__metrics { grid-template-columns: 1fr; } }

  /* ---------- method (how the winner got made) ---------- */
  .method { margin-bottom: 3.5rem; }
  .method__lead { max-width: 58ch; font-size: 1.02rem; margin-bottom: 1.8rem; }
  .method__grid { display: grid; grid-template-columns: 1.25fr 0.75fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .method__steps { list-style: none; display: flex; flex-direction: column; }
  .mstep { position: relative; display: flex; gap: 1.1rem; padding: 1.1rem 0 1.3rem 0; }
  .mstep + .mstep { border-top: 2px dashed var(--ink); }
  .mstep__n { flex: 0 0 auto; align-self: flex-start; font-size: 0.78rem; font-weight: 700; border: 2px solid var(--ink); border-radius: 999px; padding: 0.25em 0.7em; background: var(--acid); margin-top: 0.2rem; }
  .mstep__t { font-size: 1.18rem; margin-bottom: 0.4rem; }
  .mstep__d { font-size: 0.95rem; line-height: 1.5; max-width: 58ch; }
  .method__ad { position: relative; margin: 0; justify-self: center; display: flex; flex-direction: column; align-items: center; gap: 0.8rem; }
  .method__ad img { width: min(64vw, 300px); height: auto; aspect-ratio: 9 / 16; object-fit: cover; border: var(--bd) solid var(--ink); border-radius: 3px; box-shadow: var(--shadow-lg); background: var(--paper-2); transform: rotate(1.5deg); }
  .method__sticker { position: absolute; top: -14px; right: -10px; padding: 0.5em 0.9em; font-size: 0.76rem; }
  .method__cap { font-size: 1.35rem; color: var(--cobalt); transform: rotate(-2deg); text-align: center; }
  @media (max-width: 820px) { .method__grid { grid-template-columns: 1fr; } .method__ad { order: -1; } }

  .cs__gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.6rem; }
  .ad { margin: 0; }
  .ad img, .ad video { width: 100%; height: auto; aspect-ratio: 9 / 16; object-fit: cover; border: var(--bd) solid var(--ink); border-radius: 3px; box-shadow: var(--shadow); background: var(--ink); display: block; }
  .ad img { background: var(--paper-2); }
  @media (max-width: 900px) { .cs__gallery { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .cs__gallery { grid-template-columns: 1fr; } }

  .cs__next { display: block; text-decoration: none; color: var(--ink); border-top: var(--bd) solid var(--ink); }
  .cs__next-inner { display: flex; justify-content: space-between; align-items: center; padding-block: 2rem; gap: 1rem; }
  .cs__next-name { font-size: clamp(1.4rem, 4vw, 2.4rem); font-weight: 700; text-transform: uppercase; }
  .cs__next:hover .cs__next-name { text-decoration: underline 3px; text-underline-offset: 5px; }
</style>

<script>
  import { initMotion } from '../../scripts/motion.ts';
  initMotion();
</script>
