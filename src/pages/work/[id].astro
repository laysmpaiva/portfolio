---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { caseStudies } from '../../data/content.ts';

export function getStaticPaths() {
  return caseStudies.map((c, i) => ({
    params: { id: c.id },
    props: {
      c,
      next: caseStudies[(i + 1) % caseStudies.length],
    },
  }));
}

const { c, next } = Astro.props;
---

<Layout title={`${c.client} — Lays Paiva`} description={c.headline}>
  <Nav active="work" />

  <article class="cs">
    <!-- header -->
    <header class={`cs__head bg-${c.accent}`}>
      <div class="wrap">
        <a href="/#work" class="cs__back mono">← Back to work</a>
        <div class="cs__head-grid">
          <div>
            <span class="tag cs__cat">{c.category}</span>
            <h1 class="display cs__title">{c.client}</h1>
            <p class="cs__person mono">{c.person} · {c.span}</p>
            <p class="cs__headline">{c.headline}</p>
          </div>
          <figure class="cs__hero-shot r-2">
            {c.image ? (
              <>
                <img class="cs__hero-ad" src={c.image} alt={`${c.client} ad — ${c.adName}`} width="300" height="533" loading="eager" />
                {c.adName ? <figcaption class="creative__cap mono">{c.adName}</figcaption> : null}
              </>
            ) : c.face ? (
              <img class="cs__hero-face" src={c.face} alt={c.person} width="240" height="240" loading="eager" />
            ) : c.logo ? (
              <img class="cs__hero-logo" src={c.logo} alt={`${c.client} logo`} loading="eager" />
            ) : c.emoji ? (
              <span class="cs__hero-emoji" aria-hidden="true">{c.emoji}</span>
            ) : null}
          </figure>
        </div>
      </div>
    </header>

    <!-- context + what I did -->
    <section class="cs__body wrap">
      <div class="cs__cols">
        <div class="reveal">
          <h2 class="cs__h">The brief</h2>
          <p class="cs__ctx">{c.context}</p>
        </div>
        <div class="reveal">
          <h2 class="cs__h">What I did</h2>
          <ul class="cs__did">
            {c.work.map((w) => <li>{w}</li>)}
          </ul>
        </div>
      </div>

      <!-- metrics -->
      <h2 class="cs__h reveal">The numbers</h2>
      {c.spendKey ? <p class="cs__note mono muted reveal">Managed ad spend is windowed to my time on the account — not the lifetime account total.</p> : null}
      <div class="cs__metrics">
        {c.metrics.map((m) => (
          <div class="metric card reveal">
            <span class="metric__v">{m.v}</span>
            <span class="metric__k mono">{m.k}</span>
            {m.note ? <span class="metric__n muted">{m.note}</span> : null}
          </div>
        ))}
      </div>

      <!-- ad gallery -->
      {c.gallery && c.gallery.length ? (
        <>
          <h2 class="cs__h reveal">The ads <span class="cs__count mono">{c.gallery.length} creatives</span></h2>
          <div class="cs__gallery">
            {c.gallery.map((g, i) => (
              <figure class={`ad reveal r-${(i % 4) + 1}`}>
                <img src={g.src} alt={g.label} loading="lazy" width="300" height="533" />
                {g.video ? <span class="ad__play" aria-hidden="true">▶</span> : null}
                <figcaption class="ad__cap mono">{g.label}</figcaption>
                <span class="tape ad__tape" aria-hidden="true"></span>
              </figure>
            ))}
          </div>
        </>
      ) : null}
    </section>

    <!-- next -->
    <a href={`/work/${next.id}`} class={`cs__next bg-${next.accent}`}>
      <div class="wrap cs__next-inner">
        <span class="mono">Next project</span>
        <span class="cs__next-name">{next.client} →</span>
      </div>
    </a>
  </article>

  <Footer />
</Layout>

<style>
  .cs__head { border-bottom: var(--bd) solid var(--ink); padding-block: clamp(1.2rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem); }
  .cs__back { display: inline-block; font-weight: 700; text-decoration: none; margin: 0.6rem 0 1.6rem; padding: 0.4em 0.8em; border: 2px solid var(--ink); border-radius: 999px; background: var(--paper-2); }
  .cs__head-grid { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 2rem; align-items: center; }
  .cs__cat { background: var(--paper-2); }
  .cs__title { font-size: clamp(2.6rem, 8vw, 6rem); margin: 0.6rem 0 0.4rem; text-transform: uppercase; }
  .cs__person { font-weight: 700; font-size: 0.9rem; }
  .cs__headline { font-size: clamp(1.2rem, 2.6vw, 1.7rem); font-weight: 600; line-height: 1.25; margin-top: 1rem; max-width: 26ch; }
  .cs__hero-shot { margin: 0; justify-self: center; display: flex; flex-direction: column; gap: 0.6rem; align-items: center; }
  .cs__hero-ad { width: auto; height: clamp(260px, 40vh, 420px); border: var(--bd) solid var(--ink); border-radius: 3px; box-shadow: var(--shadow-lg); background: var(--paper-2); }
  .cs__hero-face { width: clamp(160px, 22vw, 240px); height: clamp(160px, 22vw, 240px); border-radius: 50%; object-fit: cover; border: var(--bd) solid var(--ink); box-shadow: var(--shadow-lg); background: var(--paper-2); }
  .cs__hero-logo { max-width: 280px; max-height: 150px; background: var(--paper-2); border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow-lg); padding: 1.4rem 1.8rem; box-sizing: border-box; object-fit: contain; }
  .cs__hero-emoji { font-size: clamp(5rem, 12vw, 9rem); line-height: 1; }
  .ad__play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 54px; height: 54px; display: grid; place-items: center; background: rgba(20,18,16,0.78); color: #fff; border: 2px solid #fff; border-radius: 50%; font-size: 1.1rem; padding-left: 3px; }
  .ad { position: relative; }
  .creative__cap, .ad__cap { font-size: 0.68rem; background: var(--paper-2); border: 2px solid var(--ink); padding: 0.25em 0.6em; border-radius: 999px; text-align: center; }
  @media (max-width: 760px) { .cs__head-grid { grid-template-columns: 1fr; } .cs__hero-shot { order: -1; } }

  .cs__body { padding-block: clamp(2.5rem, 6vw, 5rem); }
  .cs__cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; margin-bottom: 3.5rem; }
  .cs__h { font-size: clamp(1.4rem, 3.5vw, 2.2rem); text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: baseline; gap: 0.7rem; }
  .cs__count { font-size: 0.8rem; color: var(--coral); }
  .cs__ctx { font-size: 1.05rem; line-height: 1.5; }
  .cs__did { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }
  .cs__did li { position: relative; padding-left: 1.6rem; font-size: 0.98rem; line-height: 1.4; }
  .cs__did li::before { content: "▸"; position: absolute; left: 0; color: var(--coral); font-weight: 700; }
  @media (max-width: 760px) { .cs__cols { grid-template-columns: 1fr; gap: 1.8rem; } }

  .cs__note { font-size: 0.78rem; margin: -0.5rem 0 1.2rem; }
  .cs__metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-bottom: 3.5rem; }
  .metric { padding: 1.3rem 1.2rem; }
  .metric__v { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.03em; display: block; }
  .metric__k { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-top: 0.3rem; }
  .metric__n { font-size: 0.74rem; display: block; }
  @media (max-width: 700px) { .cs__metrics { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 420px) { .cs__metrics { grid-template-columns: 1fr; } }

  .cs__gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 2rem 1.6rem; }
  .ad { margin: 0; position: relative; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
  .ad img { width: 100%; max-width: 280px; height: auto; aspect-ratio: 9 / 16; object-fit: cover; border: var(--bd) solid var(--ink); border-radius: 3px; box-shadow: var(--shadow); background: var(--paper-2); transition: transform .14s ease; }
  .ad:hover img { transform: scale(1.02) rotate(-1deg); }
  .ad__tape { top: -12px; left: 50%; margin-left: -48px; }

  .cs__next { display: block; text-decoration: none; color: var(--ink); border-top: var(--bd) solid var(--ink); }
  .cs__next-inner { display: flex; justify-content: space-between; align-items: center; padding-block: 2rem; gap: 1rem; }
  .cs__next-name { font-size: clamp(1.4rem, 4vw, 2.4rem); font-weight: 700; text-transform: uppercase; }
  .cs__next:hover .cs__next-name { text-decoration: underline 3px; text-underline-offset: 5px; }
</style>

<script>
  import { initMotion } from '../../scripts/motion.ts';
  initMotion();
</script>
