---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { vsls } from '../../data/vsls.ts';

const PREVIEW_PARAS = 8;
---

<Layout title="VSL Production · Lays Paiva" description="The VSLs I wrote, produced and edited for my own direct-response offers. $1M+ in revenue, full sales letters included.">
  <Nav active="work" />

  <article class="cs">
    <header class="cs__head bg-cobalt">
      <div class="wrap">
        <a href="/#work" class="cs__back mono">← Back to work</a>
        <h1 class="display cs__title">VSL Production</h1>
        <p class="cs__headline">Before agency life I sold with video: I wrote, produced and edited the VSLs for my own direct-response offers under Deletha.</p>
        <p class="cs__intro">No client, no brief, no safety net. My copy either sold or I didn't eat. The four below are the best of that era: the offer that crossed $1M in Latin America, the first sales letter I ever wrote (almost R$1M), a R$500K weight-loss offer, and the English adaptation we shot with a US actress to go global. Each one comes with the full sales letter, because "trust me, it converted" is not a portfolio.</p>
        <div class="cs__chips">
          <span class="sticker chip-st r-2">$1M+ best offer</span>
          <span class="sticker chip-st r-1">~R$1M first letter ever</span>
          <span class="sticker chip-st r-3">4 VSLs · full scripts</span>
        </div>
      </div>
    </header>

    <section class="cs__body wrap">
      {vsls.map((v, i) => (
        <div class={`vsl card reveal accent-${['cobalt', 'coral', 'acid', 'lilac'][i % 4]}`} id={v.id}>
          <div class="vsl__head">
            <div>
              <span class="vsl__num mono">VSL {String(i + 1).padStart(2, '0')}</span>
              <h2 class="vsl__name">{v.name}</h2>
              <p class="vsl__market mono muted">{v.market}</p>
            </div>
            <span class="sticker vsl__metric r-2">{v.metric}</span>
          </div>
          <p class="vsl__blurb">{v.blurb}</p>
          <div class="vsl__frame">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${v.youtubeId}`}
              title={v.name}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>

          <h3 class="vsl__letter-h mono">The sales letter</h3>
          <div class="letter" data-letter>
            <div class="letter__body">
              {v.sections.map((s) => (
                <section class="letter__sec">
                  {s.h ? <h4 class="letter__sec-h mono">{s.h}</h4> : null}
                  {s.paras.map((p) => <p class="letter__p">{p}</p>)}
                </section>
              ))}
            </div>
            <div class="letter__fade" aria-hidden="true"></div>
          </div>
          <button class="btn btn--ghost letter__toggle" data-letter-toggle type="button">Read the full letter ↓</button>
        </div>
      ))}
    </section>

    <a href="/work/email-funnels" class="cs__next bg-acid">
      <div class="wrap cs__next-inner">
        <span class="mono">Next project</span>
        <span class="cs__next-name">Email Funnels →</span>
      </div>
    </a>
  </article>

  <Footer />
</Layout>

<style define:vars={{ previewParas: PREVIEW_PARAS }}>
  .cs__head { border-bottom: var(--bd) solid var(--ink); padding-block: clamp(1.2rem, 3vw, 2rem) clamp(2.5rem, 5vw, 4rem); color: var(--paper-2); }
  .cs__back { display: inline-block; font-weight: 700; text-decoration: none; margin: 0.6rem 0 1.6rem; padding: 0.4em 0.8em; border: 2px solid var(--ink); border-radius: 999px; background: var(--paper-2); color: var(--ink); }
  .cs__cat { background: var(--paper-2); color: var(--ink); }
  .cs__title { font-size: clamp(2.6rem, 8vw, 6rem); margin: 0.6rem 0 0.4rem; text-transform: uppercase; }
  .cs__headline { font-size: clamp(1.2rem, 2.6vw, 1.7rem); font-weight: 600; line-height: 1.25; margin-top: 1rem; max-width: 46ch; }
  .cs__intro { margin-top: 1rem; max-width: 68ch; font-size: 1.02rem; line-height: 1.5; }
  .cs__chips { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 1.4rem; }
  .chip-st { padding: 0.5em 0.9em; font-size: 0.78rem; color: var(--ink); }

  .cs__body { padding-block: clamp(2.5rem, 6vw, 5rem); display: flex; flex-direction: column; gap: clamp(2rem, 5vw, 3.5rem); }
  .vsl { padding: clamp(1.4rem, 3.5vw, 2.4rem); text-align: center; }
  .vsl__head { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
  .vsl__num { font-size: 0.78rem; font-weight: 700; border: 2px solid var(--ink); border-radius: 999px; padding: 0.2em 0.7em; color: var(--coral); }
  .vsl__name { font-size: clamp(1.5rem, 3.6vw, 2.4rem); margin-top: 0.6rem; }
  .vsl__market { font-size: 0.78rem; margin-top: 0.3rem; }
  .vsl__metric { padding: 0.5em 0.9em; font-size: 0.78rem; color: var(--ink); margin-top: 0.4rem; }
  .vsl__blurb { margin: 1rem auto 1.4rem; font-size: 1.02rem; line-height: 1.45; max-width: 70ch; }
  .vsl__frame { border: var(--bd) solid var(--ink); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; aspect-ratio: 16 / 9; background: var(--ink); max-width: 760px; margin-inline: auto; }
  .vsl__frame iframe { width: 100%; height: 100%; border: 0; display: block; }

  .vsl__letter-h { margin: 1.8rem 0 0.8rem; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--coral); }
  .letter { position: relative; max-height: 30rem; overflow: hidden; transition: max-height 0.3s ease; }
  .letter.is-open { max-height: none; }
  .letter__body { border-left: 3px solid var(--ink); padding-left: clamp(0.9rem, 2.5vw, 1.6rem); max-width: 76ch; margin-inline: auto; text-align: left; }
  .letter__sec-h { font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; background: var(--ink); color: var(--acid); display: inline-block; padding: 0.3em 0.8em; border-radius: 999px; margin: 1.4rem 0 0.7rem; }
  .letter__p { font-size: 0.97rem; line-height: 1.55; margin-bottom: 0.7rem; max-width: 72ch; }
  .letter__fade { position: absolute; left: 0; right: 0; bottom: 0; height: 9rem; background: linear-gradient(to bottom, transparent, var(--paper-2)); pointer-events: none; }
  .letter.is-open .letter__fade { display: none; }
  .letter__toggle { margin-top: 1.1rem; font-size: 0.8rem; margin-inline: auto; }

  .cs__next { display: block; text-decoration: none; color: var(--ink); border-top: var(--bd) solid var(--ink); }
  .cs__next-inner { display: flex; justify-content: space-between; align-items: center; padding-block: 2rem; gap: 1rem; }
  .cs__next-name { font-size: clamp(1.4rem, 4vw, 2.4rem); font-weight: 700; text-transform: uppercase; }
  .cs__next:hover .cs__next-name { text-decoration: underline 3px; text-underline-offset: 5px; }
</style>

<script>
  import { initMotion } from '../../scripts/motion.ts';
  initMotion();

  document.querySelectorAll('[data-letter-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const letter = btn.previousElementSibling as HTMLElement;
      const open = letter.classList.toggle('is-open');
      (btn as HTMLElement).textContent = open ? 'Collapse the letter ↑' : 'Read the full letter ↓';
      if (!open) letter.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
